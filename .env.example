# ========= 网络与接口服务 =========
# 雷达原始数据地址 (仅在启动雷达模块时有效)
RADAR_HTTP_URL=http://10.0.0.100:8008/api/spatial/radar/state

# MQTT 服务器配置 (如果你 HA 里配置了 Mosquitto)
MQTT_BROKER_HOST=10.0.0.50
MQTT_BROKER_PORT=1883
MQTT_USERNAME=admin
MQTT_PASSWORD=your_password_here

# ========= 语音服务 (Voice Stack) =========
# 本地端口与 API
KOKORO_TTS_URL=http://localhost:8000/v1/audio/speech
WHISPER_STT_URL=http://localhost:8081/v1/audio/transcriptions
# 语音终端服务地址 (radar_station 会调用它进行主动播报)
AUDIO_TERMINAL_URL=http://localhost:8000
# 接入关口 API 地址 (Hermes 或其他 LLM 代理)
AGENT_API_URL=http://10.0.0.50:8642
# API Key
API_SERVER_KEY=sk-your-api-key-here

# ========= 时区 =========
TZ=Asia/Shanghai

# ========= Home Assistant 设置 =========
HA_URL=http://10.0.0.50:8123
HA_TOKEN=YOUR_LONG_LIVED_ACCESS_TOKEN_HERE

# 传感器配置
TEMP_ENTITY_ID=sensor.living_room_temperature
HUMIDITY_ENTITY_ID=sensor.living_room_humidity

# 雷达实体配置 (Home Assistant 中的多目标雷达实体)
RADAR_COUNT_ENTITY=sensor.radar_presence_count
RADAR_X_PATTERN=sensor.radar_target_{id}_x
RADAR_Y_PATTERN=sensor.radar_target_{id}_y
RADAR_V_PATTERN=sensor.radar_target_{id}_speed

# ========= 策略配置 (Execution Strategy) =========
# 默认开启 YOLO 模式 (不询问确认直接执行)
AGENT_EXEC_STRATEGY=yolo
# 音频双工模式：'full' (全双工) 或 'half' (半双工)
AUDIO_DUPLEX_MODE=full

# 判定用户不在家的阈值 (秒)
AWAY_THRESHOLD_SECONDS=1800

# 雷达校准参数
RADAR_X=0.0
RADAR_Y=0.5
RADAR_ROTATION=135.0
RADAR_SWAP_XY=true
RADAR_SCALE=1.2
RADAR_MIRROR_X=true
RADAR_MIRROR_Y=false

# ========= 模型路径 (可选) =========
# MOSS_CHECKPOINT_PATH=/path/to/your/tokenizer.model
